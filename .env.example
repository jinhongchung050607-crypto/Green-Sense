# Google Gemini API Key (FREE - 1500 requests/day!)
# Get your API key from: https://aistudio.google.com/app/apikey
# FREE: 1500 requests/day, no credit card needed
GEMINI_API_KEY=your_gemini_api_key_here

# Plant.id API Key (OPTIONAL - enhanced plant identification)
# Get your API key from: https://web.plant.id/
# FREE: 100 identifications/day
PLANTID_API_KEY=your_plantid_api_key_here

# PlantNet API Key (OPTIONAL - backup for plant identification)
# Get your API key from: https://my.plantnet.org/
# FREE: 500 identifications/day
PLANTNET_API_KEY=your_plantnet_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=development
